# Copy to .env and fill in. .env is gitignored.

# === Provider keys ===
# Anthropic (optional, fallback)
# ANTHROPIC_API_KEY=sk-...

# Cerebras — Qwen3-235B-A22B (free, 30 RPM, 1M tokens/day)
# https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# NVIDIA NIM — Qwen3.5-397B-A17B (free credits, 40 RPM)
# https://build.nvidia.com/
NVIDIA_API_KEY=

# Chutes — Kimi K2.5 (free, 256K context, agentic-strong)
# https://chutes.ai/
CHUTES_API_KEY=

# Tavily — expert-only live medical web search / RAG
# Install with: uv sync --extra medical-kb
TAVILY_API_KEY=
# Limits documents returned by the one allowed expert web search per user turn.
MARGE_WEB_RAG_MAX_RESULTS=3
# Default: medlineplus.gov, pubmed.ncbi.nlm.nih.gov. Comma-separated domains only, not URL paths.
MEDICAL_WEB_SEARCH_INCLUDE_DOMAINS=medlineplus.gov,pubmed.ncbi.nlm.nih.gov

# === Per-role routing ===
# Orchestrator: agentic decisions over tool surface
ORCHESTRATOR_PRIMARY=chutes
ORCHESTRATOR_FALLBACK=cerebras

# Medical expert sub-agent: high-quality clinical reasoning
MEDICAL_EXPERT_PRIMARY=nvidia
MEDICAL_EXPERT_FALLBACK=cerebras

# === Optional model overrides ===
# CEREBRAS_MODEL_ID=qwen-3-235b-a22b-instruct-2507
# NVIDIA_MODEL_ID=qwen/qwen3.5-397b-a17b
# CHUTES_MODEL_ID=moonshotai/Kimi-K2.5-TEE
